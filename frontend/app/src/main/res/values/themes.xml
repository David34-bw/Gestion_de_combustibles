<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="FuelButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/fuel_white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@color/fuel_orange</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="FuelInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/fuel_orange</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/fuel_orange</item>
        <item name="android:textColorHint">@color/fuel_gray</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="CustomSpinnerStyle" parent="Widget.AppCompat.Spinner">
        <item name="android:backgroundTint">@color/fuel_orange</item>
        <item name="android:popupBackground">@color/fuel_dark_card</item>
    </style>

    <style name="Theme.AplicacionDestionDeCombustibles" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/fuel_orange</item>
        <item name="colorPrimaryVariant">@color/fuel_orange_dark</item>
        <item name="colorOnPrimary">@color/fuel_white</item>
        <item name="colorSecondary">@color/fuel_orange_light</item>
        <item name="android:windowBackground">@color/fuel_dark</item>
        <item name="android:statusBarColor">@color/fuel_dark</item>
        <item name="android:navigationBarColor">@color/fuel_dark</item>

        <!-- Para forzar el color de la caja cuando no tiene foco -->
        <item name="boxStrokeColor">@color/fuel_orange</item>
    </style>
</resources>