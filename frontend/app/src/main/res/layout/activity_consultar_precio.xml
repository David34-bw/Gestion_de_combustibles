<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fuel_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💰 Consultar Precios"
            android:textColor="@color/fuel_orange"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Precios según zona y tipo de vehículo"
            android:textColor="@color/fuel_gray"
            android:textSize="13sp"
            android:layout_marginBottom="20dp"/>

        <!-- Card filtros -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/fuel_dark_card"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zona / Región"
                    android:textColor="@color/fuel_orange"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <Spinner
                    android:id="@+id/spinner_zona"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tipo de combustible"
                    android:textColor="@color/fuel_orange"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <Spinner
                    android:id="@+id/spinner_combustible"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tipo de vehículo"
                    android:textColor="@color/fuel_orange"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <Spinner
                    android:id="@+id/spinner_vehiculo"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_consultar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Consultar Precio"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/fuel_orange"
                    android:textColor="@color/fuel_white"
                    app:cornerRadius="10dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card resultado (oculta al inicio) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tv_resultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/fuel_dark_card"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/fuel_orange"
            app:strokeWidth="1dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resultado"
                    android:textColor="@color/fuel_orange"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/tv_precio_base"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/fuel_gray_light"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_descuento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/fuel_success"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/fuel_divider"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⛽ Precio final"
                    android:textColor="@color/fuel_gray_light"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tv_precio_final"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/fuel_orange"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
