<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fuel_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <!-- Logo / ícono -->
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="48dp"
            android:src="@mipmap/ic_launcher_round"
            android:contentDescription="Logo"/>

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="FuelControl"
            android:textColor="@color/fuel_white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="40dp"
            android:text="Gestión de combustibles"
            android:textColor="@color/fuel_gray"
            android:textSize="14sp"/>

        <!-- Card formulario -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/fuel_dark_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:text="Iniciar sesión"
                    android:textColor="@color/fuel_white"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <!-- Email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Correo electrónico"
                    style="@style/FuelInput"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="@color/fuel_gray">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/fuel_white"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Contraseña -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Contraseña"
                    style="@style/FuelInput"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:startIconTint="@color/fuel_gray"
                    app:passwordToggleEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/fuel_white"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Rol -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Tipo de usuario"
                    android:textColor="@color/fuel_gray"
                    android:textSize="13sp"/>

                <RadioGroup
                    android:id="@+id/rg_role"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="24dp">

                    <RadioButton android:id="@+id/rb_usuario"
                        android:text="Usuario" android:checked="true"
                        android:textColor="@color/fuel_gray_light"
                        android:buttonTint="@color/fuel_orange"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                    <RadioButton android:id="@+id/rb_estacion"
                        android:text="Estación de servicio"
                        android:textColor="@color/fuel_gray_light"
                        android:buttonTint="@color/fuel_orange"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                    <RadioButton android:id="@+id/rb_distribuidor"
                        android:text="Distribuidor"
                        android:textColor="@color/fuel_gray_light"
                        android:buttonTint="@color/fuel_orange"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                    <RadioButton android:id="@+id/rb_regulador"
                        android:text="Entidad reguladora"
                        android:textColor="@color/fuel_gray_light"
                        android:buttonTint="@color/fuel_orange"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </RadioGroup>

                <!-- Botón login -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_login"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="INGRESAR"
                    style="@style/FuelButton"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Link registro -->
        <TextView
            android:id="@+id/tv_go_register"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            android:text="¿No tienes cuenta? Regístrate aquí"
            android:textColor="@color/fuel_orange"
            android:textSize="14sp"
            android:padding="8dp"/>

    </LinearLayout>
</ScrollView>