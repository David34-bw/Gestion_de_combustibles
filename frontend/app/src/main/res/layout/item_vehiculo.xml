<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#1E2333"
    app:cardCornerRadius="10dp"
    app:strokeColor="@color/fuel_divider"
    app:strokeWidth="1dp"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Icono -->
        <TextView
            android:id="@+id/tv_icono_vehiculo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="🚗"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginEnd="12dp"/>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_placa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABC123"
                android:textColor="@color/fuel_white"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_tipo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PARTICULAR"
                android:textColor="@color/fuel_gray_light"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tv_marca"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/fuel_gray"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Subsidio -->
        <TextView
            android:id="@+id/tv_subsidio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sin subsidio"
            android:textSize="11sp"
            android:textColor="@color/fuel_gray"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
