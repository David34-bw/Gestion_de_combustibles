<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fuel_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="8dp"
            android:text="Crear cuenta"
            android:textColor="@color/fuel_white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="Completa tus datos para registrarte"
            android:textColor="@color/fuel_gray"
            android:textSize="14sp" />

        <!-- ── CARD: Datos base ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/fuel_dark_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:letterSpacing="0.08"
                    android:text="Datos de acceso"
                    android:textColor="@color/fuel_orange"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Correo electrónico">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Contraseña"
                    app:passwordToggleEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Confirmar contraseña"
                    app:passwordToggleEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_confirm_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── CARD: Selección de rol ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/fuel_dark_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:letterSpacing="0.08"
                    android:text="Tipo de usuario"
                    android:textColor="@color/fuel_orange"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rg_role"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rb_usuario"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/fuel_orange"
                        android:checked="true"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:text="Usuario particular / subsidiado"
                        android:textColor="@color/fuel_gray_light" />

                    <RadioButton
                        android:id="@+id/rb_estacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/fuel_orange"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:text="Estación de servicio"
                        android:textColor="@color/fuel_gray_light" />

                    <RadioButton
                        android:id="@+id/rb_distribuidor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/fuel_orange"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:text="Distribuidor mayorista"
                        android:textColor="@color/fuel_gray_light" />

                    <RadioButton
                        android:id="@+id/rb_regulador"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/fuel_orange"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:text="Autoridad reguladora"
                        android:textColor="@color/fuel_gray_light" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════
             CARD USUARIO: campos dinámicos
        ══════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_usuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="visible"
            app:cardBackgroundColor="@color/fuel_dark_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:letterSpacing="0.08"
                    android:text="Datos del vehículo"
                    android:textColor="@color/fuel_orange"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Cédula -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Cédula del propietario">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_cedula"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Placa -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Placa del vehículo (ej: ABC123)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_placa"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapCharacters"
                        android:maxLength="6"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Tipo de vehículo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Tipo de vehículo"
                    android:textColor="@color/fuel_gray"
                    android:textSize="13sp" />

                <RadioGroup
                    android:id="@+id/rg_tipo_vehiculo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rb_particular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/fuel_orange"
                        android:checked="true"
                        android:text="Particular"
                        android:textColor="@color/fuel_gray_light" />

                    <RadioButton
                        android:id="@+id/rb_taxi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/fuel_orange"
                        android:text="Taxi"
                        android:textColor="@color/fuel_gray_light" />

                    <RadioButton
                        android:id="@+id/rb_moto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/fuel_orange"
                        android:text="Motocicleta"
                        android:textColor="@color/fuel_gray_light" />

                    <RadioButton
                        android:id="@+id/rb_carga"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/fuel_orange"
                        android:text="Vehículo de carga"
                        android:textColor="@color/fuel_gray_light" />
                </RadioGroup>

                <!-- Subsidio -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="¿Aplica subsidio de combustible?"
                    android:textColor="@color/fuel_gray"
                    android:textSize="13sp" />

                <RadioGroup
                    android:id="@+id/rg_subsidio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rb_subsidio_si"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="24dp"
                        android:buttonTint="@color/fuel_orange"
                        android:text="Sí"
                        android:textColor="@color/fuel_gray_light" />

                    <RadioButton
                        android:id="@+id/rb_subsidio_no"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/fuel_orange"
                        android:checked="true"
                        android:text="No"
                        android:textColor="@color/fuel_gray_light" />
                </RadioGroup>

                <!-- Número RUNT (visible solo si subsidio = Sí) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_runt"
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="N° RUNT para verificar subsidio activo"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_runt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tv_runt_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="⚠ El número RUNT se usará para consultar el estado del subsidio en la base de datos del SICOM (MinEnergía)."
                    android:textColor="@color/fuel_gray"
                    android:textSize="12sp"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════
     CARD ESTACIÓN DE SERVICIO: campos dinámicos
══════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_estacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/fuel_dark_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:letterSpacing="0.08"
                    android:text="Datos de la estación de servicio"
                    android:textColor="@color/fuel_orange"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- NIT -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="NIT de la estación (ej: 900123456-1)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_nit_estacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Nombre comercial -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Nombre comercial de la estación">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_nombre_estacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Código SICOM -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Código SICOM (MinEnergía)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_codigo_sicom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Número de licencia -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Número de licencia de operación">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_licencia_estacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Dirección -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Dirección de la estación">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_direccion_estacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPostalAddress"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Ciudad -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Ciudad">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_ciudad_estacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Departamento -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Departamento">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_departamento_estacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="⚠ El NIT y código SICOM serán verificados contra el registro de estaciones del Ministerio de Energía y MinCIT."
                    android:textColor="@color/fuel_gray"
                    android:textSize="12sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════
             CARD DISTRIBUIDOR: campos dinámicos
        ══════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_distribuidor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/fuel_dark_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:letterSpacing="0.08"
                    android:text="Datos de la empresa distribuidora"
                    android:textColor="@color/fuel_orange"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="NIT de la empresa (ej: 900123456-1)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_nit_dist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Nombre legal de la empresa">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_nombre_empresa"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Número de registro mercantil">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_registro_mercantil"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Ciudad">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_ciudad_dist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Departamento">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_departamento_dist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="⚠ El NIT y registro mercantil serán verificados contra la base de datos de la Cámara de Comercio y el RUES."
                    android:textColor="@color/fuel_gray"
                    android:textSize="12sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════
             CARD REGULADOR: campos dinámicos
        ══════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_regulador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/fuel_dark_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:letterSpacing="0.08"
                    android:text="Datos de la entidad reguladora"
                    android:textColor="@color/fuel_orange"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="NIT de la entidad estatal">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_nit_reg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Código de entidad estatal (CHIP)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_codigo_entidad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Cargo del funcionario">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_cargo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FuelInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Dependencia o Ministerio">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_dependencia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:textColor="@color/fuel_white" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="⚠ El código CHIP y NIT serán verificados contra el Directorio de Entidades Estatales del DANE y el SECOP."
                    android:textColor="@color/fuel_gray"
                    android:textSize="12sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Botón registrar ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_register"
            style="@style/FuelButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="REGISTRARSE" />

    </LinearLayout>
</ScrollView>